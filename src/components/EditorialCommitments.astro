---
const commitments = [
  'Criteria before conclusions',
  'Source transparency',
  'Conflict disclosure',
  'Open corrections',
  'No pay-to-rank',
  'Human editorial review',
  'Limitations documented',
  'Updated when evidence changes',
];
---

<ul style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1rem;margin-top:1.5rem;list-style:none;">
  {commitments.map(c => (
    <li style="display:flex;align-items:center;gap:0.75rem;background:var(--color-surface);border:1px solid var(--color-border);padding:1rem;border-radius:var(--radius);">
      <span style="color:var(--color-accent);font-weight:700;">✓</span>
      <span>{c}</span>
    </li>
  ))}
</ul>
