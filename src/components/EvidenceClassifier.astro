---
const samples = [
  { claim: 'Vendor publishes pricing publicly', verdict: 'Verified Proof', color: '#1B4D3E' },
  { claim: 'Vendor claims "best in industry"', verdict: 'Unverified Assertion', color: '#B87333' },
  { claim: 'Third-party audit scope is disclosed', verdict: 'Proof Gap', color: '#DC2626' },
];
---

<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;margin-top:2rem;">
  <p style="font-weight:600;color:var(--color-primary);margin-bottom:1rem;">Evidence Classifier Demo</p>
  {samples.map(s => (
    <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid var(--color-border);gap:1rem;">
      <span style="font-size:0.95rem;">{s.claim}</span>
      <span style="font-size:0.75rem;font-weight:600;padding:0.25rem 0.6rem;border-radius:999px;color:#fff;background:{s.color};white-space:nowrap;">{s.verdict}</span>
    </div>
  ))}
</div>
