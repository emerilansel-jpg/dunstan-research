---
---

<div style="background:var(--color-primary);color:#fff;border-radius:var(--radius);padding:2.5rem;">
  <h2 style="color:#fff;">Research Briefing</h2>
  <p style="opacity:0.8;margin-top:0.5rem;">New reports, benchmarks, and corrections. No spam. Unsubscribe anytime.</p>
  <form id="newsletter-form" style="margin-top:1.5rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
    <input type="email" name="email" placeholder="you@company.com" required style="flex:1;min-width:220px;padding:0.75rem 1rem;border:none;border-radius:var(--radius);" />
    <div style="position:absolute;left:-5000px;" aria-hidden="true">
      <input type="text" name="company" tabindex="-1" autocomplete="off" />
    </div>
    <button type="submit" style="background:var(--color-accent);color:#fff;border:none;padding:0.75rem 1.5rem;border-radius:var(--radius);font-weight:600;cursor:pointer;">Subscribe</button>
  </form>
</div>

<script>
  const newsletterForm = document.getElementById('newsletter-form');
  const newsletterStatus = document.createElement('div');
  newsletterStatus.style.marginTop = '1rem';
  newsletterForm?.after(newsletterStatus);
  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(newsletterForm);
    if (data.get('company')) {
      return;
    }
    const submitBtn = newsletterForm.querySelector('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
    try {
      const payload = {
        site: 'dunstanresearch.com',
        name: 'Newsletter Subscriber',
        email: data.get('email'),
        message: 'Subscribe to Research Briefing',
        website: data.get('company') || '',
      };
      const res = await fetch('https://research-api.n311311.workers.dev/api/form/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Server error');
      newsletterForm.reset();
      newsletterStatus.innerHTML = '<p style="color:#fff;">Thank you for subscribing.</p>';
    } catch (err) {
      newsletterStatus.innerHTML = '<p style="color:#fff;">Sorry, something went wrong. Please try again later.</p>';
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
