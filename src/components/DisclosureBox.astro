---
const { text } = Astro.props;
---

<div style="background:#FFF8E7;border:1px solid var(--color-border);border-radius:var(--radius);padding:1rem;margin:2rem 0;">
  <p style="font-weight:600;color:var(--color-primary);margin-bottom:0.25rem;">Disclosure</p>
  <p style="font-size:0.9rem;color:var(--color-text);margin:0;">{text}</p>
</div>
