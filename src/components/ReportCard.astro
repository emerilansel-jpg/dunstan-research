---
const { title, description, category, outputFormat, publishDate, slug, status = 'Live', readingTime, heroImage } = Astro.props;
---

<article style="border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;background:var(--color-surface);display:flex;flex-direction:column;height:100%;overflow:hidden;">
  {heroImage && (
    <div style="margin:-1.5rem -1.5rem 1rem -1.5rem;border-bottom:1px solid var(--color-border);overflow:hidden;border-radius:var(--radius) var(--radius) 0 0;">
      <img src={heroImage} alt={title} style="width:100%;height:160px;object-fit:cover;display:block;" />
    </div>
  )}
  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;align-items:center;">
    <span style="background:var(--color-primary);color:#fff;font-size:0.7rem;padding:0.2rem 0.5rem;border-radius:4px;text-transform:uppercase;">{outputFormat}</span>
    <span style="background:var(--color-accent);color:#fff;font-size:0.7rem;padding:0.2rem 0.5rem;border-radius:4px;">{status}</span>
    <span style="color:var(--color-muted);font-size:0.75rem;">{category}{readingTime ? ` · ${readingTime} min read` : ''}</span>
  </div>
  <h3 style="font-size:1.15rem;margin-bottom:auto;">
    <a href={`/research/${slug}`} style="color:var(--color-primary);">{title}</a>
  </h3>
  <p style="color:var(--color-muted);font-size:0.9rem;margin-top:0.75rem;">{description}</p>
  <p style="color:var(--color-muted);font-size:0.8rem;margin-top:1rem;">{publishDate}</p>
</article>
