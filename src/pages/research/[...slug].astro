---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisclosureBox from '../../components/DisclosureBox.astro';
import CorrectionCTA from '../../components/CorrectionCTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('research');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const publishDate = new Date(post.data.publishDate).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
const lastReviewed = post.data.lastReviewed
  ? new Date(post.data.lastReviewed).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })
  : publishDate;
const bodyText = post.body || '';
const readingTime = Math.max(1, Math.round(bodyText.split(/\s+/).length / 200));
const siteUrl = Astro.site?.toString() || 'https://dunstanresearch.com';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Person', name: post.data.author },
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.lastReviewed?.toISOString() || post.data.publishDate.toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'Dunstan Research Group',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteUrl).toString(),
    },
  },
};

if (post.data.reviewer) {
  articleSchema.reviewer = {
    '@type': 'Person',
    name: post.data.reviewer,
  };
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article style="max-width:780px;margin:4rem auto;padding:0 1.5rem;">
    {post.data.heroImage && (
      <img
        src={post.data.heroImage}
        alt={post.data.title}
        style="width:100%;border-radius:var(--radius);margin-bottom:2.5rem;"
      />
    )}

    <p style="color:var(--color-muted);font-size:0.9rem;">
      {post.data.outputFormat && <span style="background:var(--color-primary);color:#fff;font-size:0.65rem;padding:0.2rem 0.5rem;border-radius:4px;text-transform:uppercase;margin-right:0.5rem;">{post.data.outputFormat}</span>}
      {post.data.category && <span style="color:var(--color-accent);font-weight:600;">{post.data.category}{post.data.subcategory ? ` / ${post.data.subcategory}` : ''} · </span>}
      {post.data.author}{post.data.reviewer ? ` · Reviewed by ${post.data.reviewer}` : ''}
    </p>

    <p style="color:var(--color-muted);font-size:0.85rem;margin-top:0.5rem;">
      Published {publishDate} · Last reviewed {lastReviewed} · {readingTime} min read
    </p>

    {post.data.researchQuestion && (
      <div style="background:var(--color-surface);border-left:4px solid var(--color-accent);padding:1rem 1.25rem;margin:1.5rem 0;">
        <p style="font-weight:600;color:var(--color-primary);margin:0;">Research Question</p>
        <p style="margin:0.25rem 0 0 0;">{post.data.researchQuestion}</p>
      </div>
    )}

    <h1 style="margin-top:1rem;">{post.data.title}</h1>

    <DisclosureBox text={post.data.disclosure} />

    <div style="margin-top:2.5rem;line-height:1.9;">
      <Content />
    </div>

    {post.data.evidenceClasses && (
      <div style="margin-top:3rem;">
        <h3>Evidence Classes Used</h3>
        <ul style="margin-top:0.5rem;padding-left:1.25rem;color:var(--color-muted);">
          {post.data.evidenceClasses.map(ec => <li>{ec}</li>)}
        </ul>
      </div>
    )}

    {post.data.limitations && (
      <div style="margin-top:2rem;background:#F9F9F9;border:1px solid var(--color-border);border-radius:var(--radius);padding:1.25rem;">
        <h3 style="margin-top:0;">Limitations</h3>
        <p style="margin:0.5rem 0 0 0;color:var(--color-muted);">{post.data.limitations}</p>
      </div>
    )}

    <CorrectionCTA />
  </article>
</BaseLayout>
