import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Disclosure Policy" description="Dunstan Research Group disclosure policy — no pay-to-rank, commercial relationships, and funding model.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:800px;">
    <h1>Disclosure Policy</h1>
    <p class="page-intro">How we handle commercial relationships, funding, and conflicts of interest.</p>

    <h2 style="margin-top:2.5rem;">No Pay-to-Rank Guarantee</h2>
    <p style="margin-top:1rem;line-height:1.8;">
      Dunstan Research Group does not accept payment in exchange for placement, ranking, positive coverage, or inclusion in a benchmark. We do not sell "featured" positions. Scores and rankings reflect documented evidence against published criteria only.
    </p>

    <h2 style="margin-top:2.5rem;">Commercial Relationship Disclosure</h2>
    <p style="margin-top:1rem;line-height:1.8;">
      Every report discloses whether Dunstan or its reviewers have any commercial relationship with covered entities. A material relationship includes direct payment, advisory contracts, equity, speaking fees, or referral arrangements within the past 24 months.
    </p>

    <h2 style="margin-top:2.5rem;">Funding Model</h2>
    <p style="margin-top:1rem;line-height:1.8;">
      Dunstan Research Group is funded by subscription research, bespoke advisory engagements, and licensing. Editorial decisions are separated from commercial teams. Sponsored or commissioned research, when produced, is clearly labeled and subject to the same methodology and disclosure standards.
    </p>

    <h2 style="margin-top:2.5rem;">What Counts as Material</h2>
    <ul style="margin-top:1rem;padding-left:1.5rem;line-height:1.9;">
      <li>Any payment from a covered entity exceeding $1,000 in the prior 24 months.</li>
      <li>Equity, options, or convertible instruments in a covered entity.</li>
      <li>Advisory or consulting relationships with a covered entity.</li>
      <li>Employment by a covered entity within the prior 24 months.</li>
      <li>Personal relationships that could reasonably influence judgment.</li>
    </ul>

    <h2 style="margin-top:2.5rem;">General Disclaimer</h2>
    <p style="margin-top:1rem;line-height:1.8;">
      Our research is for informational purposes and does not constitute investment, legal, or procurement advice. Readers should conduct their own due diligence before making decisions based on our reports.
    </p>
  </div>
</BaseLayout>
