---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Press & Citations" description="External citations and media mentions of Dunstan Research Group.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:800px;">
    <h1>Press & Citations</h1>
    <p class="page-intro">A ledger of third-party citations, media mentions, and academic references.</p>

    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:2rem;margin-top:2rem;">
      <p style="font-size:1.05rem;line-height:1.8;">
        No third-party citations have been independently verified for inclusion yet. This ledger is updated as recognition is documented. If you have cited Dunstan Research Group and would like your publication listed here, please contact <a href="mailto:editorial@dunstanresearch.com">editorial@dunstanresearch.com</a>.
      </p>
    </div>

    <h2 style="margin-top:3rem;">Citation Standards</h2>
    <p style="margin-top:1rem;line-height:1.8;">
      When citing our work, please include the report title, URL, publication date, and a reference to our methodology and limitations. Do not present editorial interpretation as independent fact.
    </p>
  </div>
</BaseLayout>
