---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Dunstan Research Group.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:680px;">
    <h1>Contact Us</h1>
    <p class="page-intro">Reach the research desk, editorial team, or corrections pathway.</p>

    <div style="margin-top:2.5rem;display:grid;gap:2rem;">
      <div>
        <h2>Send a Message</h2>
        <form id="contact-form" style="margin-top:1.25rem;display:grid;gap:1rem;">
          <div>
            <label for="contact-name" style="display:block;font-weight:600;margin-bottom:0.35rem;">Name</label>
            <input type="text" id="contact-name" name="name" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);" />
          </div>
          <div>
            <label for="contact-email" style="display:block;font-weight:600;margin-bottom:0.35rem;">Email</label>
            <input type="email" id="contact-email" name="email" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);" />
          </div>
          <div>
            <label for="contact-topic" style="display:block;font-weight:600;margin-bottom:0.35rem;">Topic</label>
            <select id="contact-topic" name="topic" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);background:var(--color-surface);">
              <option value="" disabled selected>Select a topic</option>
              <option value="General Enquiry">General Enquiries</option>
              <option value="Editorial Desk">Editorial Desk</option>
              <option value="Corrections & Evidence">Corrections & Evidence</option>
            </select>
          </div>
          <div>
            <label for="contact-message" style="display:block;font-weight:600;margin-bottom:0.35rem;">Message</label>
            <textarea id="contact-message" name="message" rows="5" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);resize:vertical;"></textarea>
          </div>
          <div style="position:absolute;left:-5000px;" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn-primary" style="justify-self:start;">Send Message</button>
        </form>
      </div>

      <div>
        <h3>General Enquiries</h3>
        <p style="margin-top:0.5rem;"><a href="mailto:research@dunstanresearch.com">research@dunstanresearch.com</a></p>
      </div>
      <div>
        <h3>Editorial Desk</h3>
        <p style="margin-top:0.5rem;"><a href="mailto:editorial@dunstanresearch.com">editorial@dunstanresearch.com</a></p>
      </div>
      <div>
        <h3>Corrections & Evidence</h3>
        <p style="margin-top:0.5rem;"><a href="mailto:corrections@dunstanresearch.com">corrections@dunstanresearch.com</a></p>
      </div>
      <div>
        <h3>Office</h3>
        <p style="margin-top:0.5rem;">
          555 Montgomery Street, Suite 900<br/>
          San Francisco, CA 94111<br/>
          United States
        </p>
      </div>
      <div>
        <h3>Phone</h3>
        <p style="margin-top:0.5rem;">+1 415 555 0173</p>
      </div>
    </div>
  </div>

  <script>
    const contactForm = document.getElementById('contact-form');
    const contactStatus = document.createElement('div');
    contactStatus.id = 'contact-status';
    contactForm?.after(contactStatus);
    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(contactForm);
      if (data.get('website')) {
        return;
      }
      const submitBtn = contactForm.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      try {
        const payload = {
          site: 'dunstanresearch.com',
          name: data.get('name'),
          email: data.get('email'),
          message: `Topic: ${data.get('topic')}\n\n${data.get('message')}`,
          website: '',
        };
        const res = await fetch('https://research-api.n311311.workers.dev/api/form/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('Server error');
        contactForm.reset();
        contactStatus.innerHTML = '<p style="color:var(--color-success);margin-top:1rem;">Thank you. We have received your message.</p>';
      } catch (err) {
        contactStatus.innerHTML = '<p style="color:var(--color-danger);margin-top:1rem;">Sorry, something went wrong. Please try again later.</p>';
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
