---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The requested page could not be found on Dunstan Research Group.">
  <section class="page-section" style="background:var(--color-surface);">
    <div class="container" style="text-align:center;max-width:640px;padding:6rem 1rem;">
      <h1 style="font-size:clamp(3rem,8vw,6rem);color:var(--color-primary);margin-bottom:1rem;">404</h1>
      <p style="font-size:1.25rem;color:var(--color-text);margin-bottom:2rem;">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </section>
</BaseLayout>
