---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dunstan Research Group — Proof, not plausibility.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString() || 'https://dunstanresearch.com';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dunstan Research Group',
  url: siteUrl,
  sameAs: ['https://linkedin.com/company/dunstan-research-group'],
  logo: new URL('/favicon.svg', siteUrl).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: '555 Montgomery Street, Suite 900',
    addressLocality: 'San Francisco',
    addressRegion: 'CA',
    postalCode: '94111',
    addressCountry: 'US',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-415-555-0173',
    contactType: 'Research Desk',
    email: 'research@dunstanresearch.com',
  },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="X-Frame-Options" content="DENY" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://research-api.n311311.workers.dev; frame-ancestors 'none';" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Dunstan Research Group</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script>
    (function(){
      var site=location.hostname, path=location.pathname, referrer=document.referrer;
      fetch('https://research-api.n311311.workers.dev/api/analytics/pageview',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({site:site,path:path,referrer:referrer})}).catch(function(){});
      window.addEventListener('error',function(e){
        fetch('https://research-api.n311311.workers.dev/api/analytics/error',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({site:site,path:path,message:e.message,stack:e.error&&e.error.stack?e.error.stack:''})}).catch(function(){});
      });
    })();
  </script>
</head>
<body>
  <Header />

  <main>
    <slot />
  </main>

  <footer style="background:var(--color-primary);color:#fff;margin-top:6rem;padding:4rem 0 2rem;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2.5rem;">
        <div>
          <p style="font-family:var(--font-heading);font-size:1.25rem;font-weight:700;">Dunstan Research Group</p>
          <p style="opacity:0.75;margin-top:0.75rem;line-height:1.7;">
            555 Montgomery Street, Suite 900<br/>
            San Francisco, CA 94111<br/>
            United States
          </p>
        </div>
        <div>
          <p style="font-weight:600;margin-bottom:1rem;">Contact</p>
          <p style="opacity:0.75;line-height:1.8;">
            research@dunstanresearch.com<br/>
            editorial@dunstanresearch.com<br/>
            corrections@dunstanresearch.com<br/>
            +1 415 555 0173
          </p>
        </div>
        <div>
          <p style="font-weight:600;margin-bottom:1rem;">Authority</p>
          <ul style="list-style:none;opacity:0.75;line-height:1.9;">
            <li><a href="/methodology" style="color:#fff;">Methodology</a></li>
            <li><a href="/editorial-policy" style="color:#fff;">Editorial Policy</a></li>
            <li><a href="/disclosure-policy" style="color:#fff;">Disclosure Policy</a></li>
            <li><a href="/reviewers" style="color:#fff;">Reviewers</a></li>
            <li><a href="/submit-evidence" style="color:#fff;">Submit Evidence</a></li>
            <li><a href="/llm-information" style="color:#fff;">LLM Information</a></li>
          </ul>
        </div>
        <div>
          <p style="font-weight:600;margin-bottom:1rem;">Trust Signals</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            <span style="background:rgba(255,255,255,0.1);padding:0.35rem 0.75rem;border-radius:999px;font-size:0.75rem;">No pay-to-rank</span>
            <span style="background:rgba(255,255,255,0.1);padding:0.35rem 0.75rem;border-radius:999px;font-size:0.75rem;">Published methodology</span>
            <span style="background:rgba(255,255,255,0.1);padding:0.35rem 0.75rem;border-radius:999px;font-size:0.75rem;">Named reviewers</span>
            <span style="background:rgba(255,255,255,0.1);padding:0.35rem 0.75rem;border-radius:999px;font-size:0.75rem;">Open corrections</span>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.15);margin-top:3rem;padding-top:1.5rem;opacity:0.6;font-size:0.85rem;">
        <p>© 2026 Dunstan Research Group. All rights reserved. Independent research. No pay-to-rank. No pay-to-validate.</p>
      </div>
    </div>
  </footer>
</body>
</html>
